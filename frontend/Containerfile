FROM docker.io/oven/bun:alpine AS build

WORKDIR /app

COPY package.json bun.lock* ./
COPY tsconfig.json ./

RUN --mount=type=cache,target=/root/.cache/bun \
  bun install --frozen-lockfile

COPY frontend/ ./frontend/

RUN echo "=== Current directory ===" && pwd && \
  echo "=== Files in /app ===" && ls -la /app && \
  echo "=== Files in /app/frontend ===" && ls -la /app/frontend && \
  echo "=== Content of tsconfig.json ===" && cat /app/tsconfig.json && \
  echo "=== Content of package.json ===" && cat /app/package.json && \
  echo "=== Content of build.ts ===" && cat /app/frontend/build.ts

RUN bun run build

FROM docker.io/oven/bun:alpine AS runtime

WORKDIR /app

ENV NODE_ENV=production

COPY --from=build /app/frontend/dist ./dist

EXPOSE 3000

CMD ["bun", "serve", "dist", "--port", "3000"]
