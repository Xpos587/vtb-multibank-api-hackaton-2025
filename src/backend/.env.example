# Application settings
APP_NAME=vtb-multibank-api
APP_VERSION=0.1.0
APP_DEBUG=true
APP_ENVIRONMENT=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_TIMEZONE=UTC

# Database settings
DATABASE_URL=postgresql://postgres:password@localhost:5432/vtb_bank
DATABASE_URL_ASYNC=postgresql+asyncpg://postgres:password@localhost:5432/vtb_bank
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_DB=vtb_bank
DATABASE_USER=postgres
DATABASE_PASSWORD=password
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=3600

# Security settings
SECURITY_JWT_PRIVATE_KEY=MIGHAgEAMBMGByqGSM49AgEGCCqGSM49AwEHBG0wawIBAQQg...
SECURITY_JWT_PUBLIC_KEY=MFkwEwYHKoZIzj0CAQYIKoZIzj0DAQcDQgAE...
SECURITY_JWT_ALGORITHM=ES256
SECURITY_ACCESS_TOKEN_EXPIRE_MINUTES=30
SECURITY_REFRESH_TOKEN_EXPIRE_DAYS=7
SECURITY_RATE_LIMIT_REQUESTS=100
SECURITY_RATE_LIMIT_WINDOW=60
SECURITY_MAX_FAILED_ATTEMPTS=10
SECURITY_IP_BLOCK_DURATION=300

# CORS settings
CORS_ORIGINS=["http://localhost:3000","http://localhost:4321"]
CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE=3600

# Logging settings
# Note: LOG_FORMAT is hardcoded and not configurable via environment
LOG_LEVEL=INFO
LOG_ENABLE_REQUEST_LOGGING=true
LOG_ENABLE_SQL_LOGGING=false
