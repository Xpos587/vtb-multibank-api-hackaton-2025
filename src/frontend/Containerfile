FROM docker.io/oven/bun:alpine AS build

WORKDIR /app

COPY package.json bun.lock* ./
COPY tsconfig.json ./

RUN --mount=type=cache,target=/root/.cache/bun \
  bun install --frozen-lockfile

COPY src/frontend/ ./src/frontend/

RUN bun run src/frontend/build.ts --outdir /app/src/frontend/dist

FROM docker.io/oven/bun:alpine AS runtime

WORKDIR /app

ENV NODE_ENV=production

COPY --from=build /app/src/frontend/dist ./dist

EXPOSE 3000

CMD ["bun", "serve", "dist", "--port", "3000"]
