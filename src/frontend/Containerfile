FROM docker.io/oven/bun:alpine AS build

WORKDIR /app

COPY package.json bun.lock* ./
COPY tsconfig.json ./

RUN --mount=type=cache,target=/root/.cache/bun \
  bun install --frozen-lockfile

COPY src/frontend/ ./frontend/

# Create temporary tsconfig.json for container build
RUN sed 's|"@/\*": \["\.\/src\/frontend\/\*"\]|"@/*": ["./frontend/*"]|' tsconfig.json > tsconfig.build.json

RUN cd /app && bun run frontend/build.ts --outdir frontend/dist

FROM docker.io/oven/bun:alpine AS runtime

WORKDIR /app

ENV NODE_ENV=production

COPY --from=build /app/frontend/dist ./dist

EXPOSE 3000

CMD ["bun", "serve", "dist", "--port", "3000"]